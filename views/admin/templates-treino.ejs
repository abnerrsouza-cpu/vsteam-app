<%- include('../partials/head') %>
<div class="app">
  <%- include('../partials/sidebar-admin') %>
  <main class="main">
    <div class="topbar">
      <div>
        <h1>Templates de Treino</h1>
        <p class="text-muted mb-0">Crie um treino uma vez e aplique em vários alunos com 1 clique.</p>
      </div>
    </div>
    <%- include('../partials/flash') %>

    <div class="grid grid-2">
      <div class="card">
        <h3>Novo Template</h3>
        <form action="/admin/templates-treino" method="POST">
          <div class="form-row"><label>Nome *</label><input type="text" name="name" required placeholder="Push A — Iniciante"></div>
          <div class="form-row"><label>Descrição</label><textarea name="description" rows="2" placeholder="Para quem se aplica, observações gerais..."></textarea></div>
          <div class="form-grid">
            <div class="form-row">
              <label>Foco</label>
              <select name="focus"><option>Hipertrofia</option><option>Força</option><option>Resistência</option><option>Definição</option><option>Funcional</option></select>
            </div>
            <div class="form-row">
              <label>Letra do dia (sugestão)</label>
              <input type="text" name="day_label" placeholder="A, B, C..." maxlength="4">
            </div>
          </div>
          <div class="form-row"><label>Notas internas</label><textarea name="notes" rows="2"></textarea></div>
          <button class="btn" type="submit">Criar e adicionar exercícios</button>
        </form>
      </div>

      <div class="card">
        <h3>Como funciona</h3>
        <p class="fs-sm text-muted">1. Crie um template aqui (ex: "Push A — Iniciante").</p>
        <p class="fs-sm text-muted">2. Adicione os exercícios padrão (séries, reps, descanso).</p>
        <p class="fs-sm text-muted">3. No detalhe de qualquer cliente, clique em <b>"Aplicar template"</b> e o treino completo é copiado pra ele em 1 clique.</p>
        <p class="fs-sm text-muted">4. Cada aplicação cria uma cópia editável — você pode ajustar carga/notas pra cada aluno.</p>
      </div>
    </div>

    <div class="card mt-3">
      <h3>Templates existentes (<%= tpls.length %>)</h3>
      <% if (tpls.length === 0) { %>
        <p class="text-muted text-center" style="padding:30px">Nenhum template ainda. Crie o primeiro ao lado.</p>
      <% } else { %>
        <div class="grid grid-auto">
          <% tpls.forEach(function(tpl){ %>
            <a href="/admin/templates-treino/<%= tpl.id %>" class="client-card">
              <div class="ava" style="background:linear-gradient(135deg,var(--primary),var(--primary-dim))"><%= tpl.day_label || tpl.name.charAt(0).toUpperCase() %></div>
              <div class="name"><%= tpl.name %></div>
              <div class="sub"><%= tpl.focus || '—' %></div>
              <% if (tpl.description) { %><p class="fs-sm text-muted" style="margin:8px 0"><%= tpl.description.length > 80 ? tpl.description.slice(0,80) + '…' : tpl.description %></p><% } %>
              <div class="meta">
                <span class="k">Exercícios</span>
                <span class="v"><%= tpl.ex_count %></span>
              </div>
            </a>
          <% }); %>
        </div>
      <% } %>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
