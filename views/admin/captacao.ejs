<%- include('../partials/head') %>
<div class="app">
  <%- include('../partials/sidebar-admin') %>
  <main class="main">
    <div class="topbar">
      <div>
        <h1>Captação de Leads</h1>
        <p class="text-muted mb-0">Registre todo lead novo — academia, story, indicação.</p>
      </div>
    </div>
    <%- include('../partials/flash') %>

    <div class="grid grid-2">
      <div class="card">
        <h3>+ Novo Lead</h3>
        <form action="/admin/captacao" method="POST">
          <div class="form-row">
            <label>Nome *</label>
            <input type="text" name="name" required>
          </div>
          <div class="form-grid">
            <div class="form-row">
              <label>Telefone/Whatsapp</label>
              <input type="tel" name="phone" placeholder="+55 11 9...">
            </div>
            <div class="form-row">
              <label>Instagram</label>
              <input type="text" name="instagram" placeholder="@usuario">
            </div>
          </div>
          <div class="form-grid">
            <div class="form-row">
              <label>Origem *</label>
              <select name="source" required>
                <option value="academia">Academia (boca a boca)</option>
                <option value="story">Repost de story Instagram</option>
                <option value="indicacao">Indicação de cliente</option>
                <option value="outro">Outro</option>
              </select>
            </div>
            <div class="form-row">
              <label>Indicado por</label>
              <input type="text" name="referred_by" placeholder="Nome de quem indicou">
            </div>
          </div>
          <div class="form-row">
            <label>Anotações / Contexto</label>
            <textarea name="notes" placeholder="Como foi o contato, o que ele busca, dor, urgência..."></textarea>
          </div>
          <button class="btn btn-block" type="submit">Cadastrar Lead</button>
        </form>
      </div>

      <div class="card">
        <h3>Em Captação — <%= leads.length %> lead<%= leads.length === 1 ? '' : 's' %></h3>
        <p class="text-muted">Converse no Whatsapp/Direct e avance pro próximo estágio.</p>
        <% if (leads.length === 0) { %>
          <p class="text-muted text-center mt-3">Ninguém em captação no momento. 📭</p>
        <% } else { %>
          <% leads.forEach(function(l){ %>
            <div class="pipeline-card" style="margin-bottom:10px">
              <div class="flex-between">
                <div>
                  <div class="pc-name"><%= l.name %></div>
                  <div class="pc-sub">
                    <% if (l.phone) { %>📱 <%= l.phone %><% } %>
                    <% if (l.instagram) { %> · <%= l.instagram %><% } %>
                  </div>
                  <div class="pc-src">Origem: <%= l.source %><%= l.referred_by ? ' · Por ' + l.referred_by : '' %></div>
                  <% if (l.notes) { %><div class="fs-sm text-muted mt-1"><%= l.notes %></div><% } %>
                </div>
                <a href="/admin/leads/<%= l.id %>" class="btn btn-sm">Abrir</a>
              </div>
              <form action="/admin/leads/<%= l.id %>/stage" method="POST" class="flex-gap mt-2">
                <input type="hidden" name="stage" value="conversa">
                <button class="btn btn-sm btn-outline" type="submit">→ Em conversa</button>
              </form>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/foot') %>
