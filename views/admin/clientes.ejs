<%- include('../partials/head') %>
<div class="app">
  <%- include('../partials/sidebar-admin') %>
  <main class="main">
    <div class="topbar">
      <div>
        <h1>Todos os Alunos</h1>
        <p class="text-muted mb-0"><%= clientes.length %> aluno<%= clientes.length === 1 ? '' : 's' %> cadastrado<%= clientes.length === 1 ? '' : 's' %>.</p>
      </div>
      <a href="/admin/clientes/novo" class="btn">+ Novo Aluno</a>
    </div>
    <%- include('../partials/flash') %>

    <% if (clientes.length === 0) { %>
      <div class="card text-center">
        <h3>Sem alunos ainda</h3>
        <p class="text-muted">Cadastre manualmente, gere um link de convite ou converta um lead.</p>
        <div class="flex-gap gap-1 mt-2" style="justify-content:center">
          <a href="/admin/clientes/novo" class="btn">Cadastrar manualmente</a>
          <a href="/admin/convites" class="btn btn-outline">Gerar link de convite</a>
        </div>
      </div>
    <% } else { %>
      <div class="list-toolbar">
        <div class="search-box">
          <input type="text" placeholder="Buscar por nome, email, plano..." data-search-target=".aluno-row">
        </div>
        <select data-filter-target=".aluno-row">
          <option value="">Todos os status</option>
          <option value="ativo">Ativos</option>
          <option value="implementacao">Em implementação</option>
          <option value="pausado">Pausados</option>
          <option value="encerrado">Encerrados</option>
        </select>
        <div class="view-toggle">
          <button data-view="cards" class="active">Cards</button>
          <button data-view="list">Lista</button>
        </div>
      </div>

      <form action="/admin/clientes/excluir-em-massa" method="POST" data-bulk-form="#bulkBar" data-confirm="Confirmar exclusão dos alunos selecionados? Esta ação é permanente.">
        <div id="bulkBar" class="bulk-bar">
          <strong>📌 <span class="count">0</span> selecionado(s)</strong>
          <button class="btn btn-sm" type="submit" style="background:var(--danger);margin-left:auto">Excluir selecionados</button>
        </div>

        <div data-view-wrap>
          <div class="cards-view active grid grid-auto" style="gap:14px">
            <% clientes.forEach(function(c){ %>
              <div class="aluno-row client-card" data-filter="<%= c.status %>"
                   data-search-text="<%= c.name %> <%= c.email %> <%= c.plan || '' %> <%= c.phone || '' %> <%= c.instagram || '' %>"
                   style="position:relative">
                <input type="checkbox" name="ids" value="<%= c.id %>"
                       style="position:absolute;top:14px;right:14px;width:18px;height:18px;cursor:pointer;z-index:2"
                       onclick="event.stopPropagation()">
                <a href="/admin/clientes/<%= c.id %>" style="display:block;text-decoration:none;color:inherit">
                  <div class="ava"><%= c.name.charAt(0).toUpperCase() %></div>
                  <div class="name"><%= c.name %></div>
                  <div class="sub"><%= c.email %></div>
                  <div class="flex-gap gap-1 mb-2" style="flex-wrap:wrap">
                    <span class="badge <%= c.status === 'ativo' ? 'badge-success' : (c.status === 'implementacao' ? 'badge-info' : 'badge-outline') %>"><%= c.status %></span>
                    <% if (c.plan) { %><span class="badge badge-outline"><%= c.plan %></span><% } %>
                  </div>
                  <div class="meta"><span class="k">Semana</span><span class="v"><%= c.current_week %></span></div>
                  <div class="meta"><span class="k">Gym Cats</span><span class="v" style="color:var(--accent)"><%= c.gym_cats_points %> pts</span></div>
                  <div class="meta" style="border:0"><span class="k">Contato</span><span class="v"><%= c.phone || c.instagram || '—' %></span></div>
                </a>
              </div>
            <% }); %>
          </div>

          <div class="list-view">
            <div class="list-view-row" style="background:var(--bg-soft);font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--text-muted);font-weight:700;cursor:default">
              <input type="checkbox" data-check-all style="width:16px;height:16px">
              <span></span>
              <span>Aluno</span>
              <span>Plano</span>
              <span>Status</span>
            </div>
            <% clientes.forEach(function(c){ %>
              <div class="list-view-row aluno-row" data-filter="<%= c.status %>"
                   data-search-text="<%= c.name %> <%= c.email %> <%= c.plan || '' %>"
                   onclick="if(event.target.tagName !== 'INPUT') location.href='/admin/clientes/<%= c.id %>'">
                <input type="checkbox" name="ids" value="<%= c.id %>" onclick="event.stopPropagation()">
                <div class="ava"><%= c.name.charAt(0).toUpperCase() %></div>
                <div class="info">
                  <strong><%= c.name %></strong>
                  <span class="sub"><%= c.email %> · S<%= c.current_week %></span>
                </div>
                <div><%= c.plan || '—' %></div>
                <span class="badge <%= c.status === 'ativo' ? 'badge-success' : (c.status === 'implementacao' ? 'badge-info' : 'badge-outline') %>"><%= c.status %></span>
              </div>
            <% }); %>
          </div>
        </div>
      </form>
    <% } %>
  </main>
</div>
<%- include('../partials/foot') %>
