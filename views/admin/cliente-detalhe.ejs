    <!-- MODAL: COMPARAR FOTOS -->
    <% if (photos && photos.length >= 2) { %>
      <div id="comparaModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.92); z-index:9999; padding:18px; overflow:auto">
        <div style="max-width:1200px; margin:0 auto">
          <div class="flex-between mb-2">
            <h2 style="margin:0; color:#fff">Comparar fotos</h2>
            <button type="button" class="btn btn-ghost" id="comparaClose" style="color:#fff; font-size:20px">×</button>
          </div>
          <div id="comparaSelector">
            <p style="color:#ccc">Clique em 2 fotos: a primeira vira "Antes", a segunda vira "Depois".</p>
            <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(140px, 1fr)); gap:10px; margin-top:14px">
              <% photos.forEach(function(p){ %>
                <button type="button" class="compara-pick" data-pid="<%= p.id %>" data-src="/uploads/<%= p.filename %>"
                        style="background:transparent; border:3px solid transparent; padding:0; border-radius:8px; overflow:hidden; cursor:pointer; position:relative">
                  <img src="/uploads/<%= p.filename %>" alt="" style="width:100%; height:160px; object-fit:cover; display:block">
                  <span class="compara-tag" style="position:absolute; top:6px; left:6px; padding:3px 8px; border-radius:10px; font-size:10px; font-weight:700; display:none"></span>
                  <span style="position:absolute; bottom:6px; right:6px; padding:2px 6px; background:rgba(0,0,0,0.7); color:#fff; font-size:10px; border-radius:4px">
                    <%= (p.taken_at || "").slice(0,10).split("-").reverse().join("/") %>
                  </span>
                </button>
              <% }); %>
            </div>
          </div>
          <div id="comparaVisao" style="display:none">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px">
              <div style="text-align:center">
                <div style="color:#fff; padding:8px; background:#333; border-radius:6px 6px 0 0; font-weight:700; letter-spacing:2px">ANTES</div>
                <img id="comparaImgA" src="" alt="" style="width:100%; max-height:78vh; object-fit:contain; background:#000">
              </div>
              <div style="text-align:center">
                <div style="color:#fff; padding:8px; background:var(--primary); border-radius:6px 6px 0 0; font-weight:700; letter-spacing:2px">DEPOIS</div>
                <img id="comparaImgB" src="" alt="" style="width:100%; max-height:78vh; object-fit:contain; background:#000">
              </div>
            </div>
            <div class="flex-gap gap-1" style="justify-content:center; margin-top:18px">
              <button type="button" class="btn btn-outline" id="comparaTrocar" style="color:#fff; border-color:#fff">Trocar fotos</button>
              <button type="button" class="btn" id="comparaFechar">Fechar</button>
            </div>
          </div>
        </div>
      </div>
      <script>
      (function(){
        const modal = document.getElementById('comparaModal');
        const selector = document.getElementById('comparaSelector');
        const visao = document.getElementById('comparaVisao');
        const imgA = document.getElementById('comparaImgA');
        const imgB = document.getElementById('comparaImgB');
        let picked = [];
        function open() { modal.style.display='block'; document.body.style.overflow='hidden'; reset(); }
        function close() { modal.style.display='none'; document.body.style.overflow=''; }
        function reset() {
          picked = []; selector.style.display=''; visao.style.display='none';
          document.querySelectorAll('.compara-pick').forEach(b => {
            b.style.borderColor='transparent';
            b.querySelector('.compara-tag').style.display='none';
          });
        }
        function render() {
          if (picked.length === 2) {
            imgA.src = picked[0].src; imgB.src = picked[1].src;
            selector.style.display='none'; visao.style.display='';
          }
        }
        document.getElementById('btnAbrirComparar')?.addEventListener('click', open);
        document.getElementById('comparaClose').addEventListener('click', close);
        document.getElementById('comparaFechar').addEventListener('click', close);
        document.getElementById('comparaTrocar').addEventListener('click', reset);
        modal.addEventListener('click', e => { if (e.target === modal) close(); });
        document.querySelectorAll('.compara-pick').forEach(btn => {
          btn.addEventListener('click', () => {
            const pid = btn.dataset.pid, src = btn.dataset.src;
            const idx = picked.findIndex(p => p.id === pid);
            if (idx >= 0) {
              picked.splice(idx, 1);
              btn.style.borderColor='transparent';
              btn.querySelector('.compara-tag').style.display='none';
            } else if (picked.length < 2) {
              picked.push({id:pid, src:src});
              const isFirst = picked.length === 1;
              btn.style.borderColor = isFirst ? '#888' : 'var(--primary)';
              const tag = btn.querySelector('.compara-tag');
              tag.textContent = isFirst ? 'ANTES' : 'DEPOIS';
              tag.style.background = isFirst ? '#888' : 'var(--primary)';
              tag.style.color = '#fff';
              tag.style.display = '';
            }
            render();
          });
        });
        window.addEventListener('vsteam-compare-pick', (e) => {
          open();
          const btn = document.querySelector('.compara-pick[data-pid="' + e.detail + '"]');
          if (btn) btn.click();
        });
      })();
      </script>
    <% } %>


    <!-- MODAL: DUPLICAR TREINO -->
    <% if (typeof outrosAlunos !== 'undefined' && outrosAlunos.length > 0) { %>
    <div id="dupTreinoModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:9999; padding:20px; overflow:auto">
      <div style="max-width:500px; margin:60px auto; background:var(--bg-card); border:1px solid var(--border); border-radius:14px; padding:24px">
        <div class="flex-between mb-2">
          <h3 style="margin:0">Duplicar treino</h3>
          <button type="button" id="dupClose" style="background:none; border:0; color:var(--text-muted); font-size:24px; cursor:pointer">×</button>
        </div>
        <p class="fs-sm text-muted" id="dupSubtitle">Escolha o aluno destino. Todos os exercícios são copiados.</p>
        <form action="" method="POST" id="dupForm">
          <input type="hidden" name="target_client_id" id="dupTargetId">
          <div class="form-row">
            <label>Aluno destino</label>
            <select id="dupTargetSelect" required>
              <option value="">— selecione —</option>
              <% outrosAlunos.forEach(function(a){ %>
                <option value="<%= a.id %>"><%= a.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-row">
            <label>Semana destino (opcional)</label>
            <input type="number" name="week_number" min="1" placeholder="Padrão: semana atual do aluno">
            <small class="text-muted fs-sm">Se em branco, usa a semana atual do aluno destino.</small>
          </div>
          <div class="flex-gap gap-1" style="margin-top:14px">
            <button type="button" class="btn btn-ghost" id="dupCancel">Cancelar</button>
            <button type="submit" class="btn" style="flex:1">Duplicar treino</button>
          </div>
        </form>
      </div>
    </div>
    <script>
    (function(){
      const modal = document.getElementById('dupTreinoModal');
      const form = document.getElementById('dupForm');
      const subtitle = document.getElementById('dupSubtitle');
      const targetSelect = document.getElementById('dupTargetSelect');
      const targetHidden = document.getElementById('dupTargetId');

      function open(workoutId, workoutName) {
        form.action = '/admin/treinos/' + workoutId + '/duplicar';
        subtitle.innerHTML = 'Duplicando <strong>' + workoutName + '</strong> para outro aluno.';
        targetSelect.value = '';
        targetHidden.value = '';
        modal.style.display = 'block';
        document.body.style.overflow = 'hidden';
      }
      function close() {
        modal.style.display = 'none';
        document.body.style.overflow = '';
      }

      document.querySelectorAll('.btn-dup-treino').forEach(b => {
        b.addEventListener('click', () => open(b.dataset.workoutId, b.dataset.workoutName));
      });
      document.getElementById('dupClose').addEventListener('click', close);
      document.getElementById('dupCancel').addEventListener('click', close);
      modal.addEventListener('click', e => { if (e.target === modal) close(); });

      targetSelect.addEventListener('change', () => { targetHidden.value = targetSelect.value; });
      form.addEventListener('submit', e => {
        if (!targetSelect.value) { e.preventDefault(); alert('Selecione um aluno destino.'); }
      });
    })();
    </script>
    <% } %>


