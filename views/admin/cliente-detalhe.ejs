                  <option value="-300">Cutting leve (déficit 300 kcal)</option>
                  <option value="0" selected>Manutenção</option>
                  <option value="300">Bulking leve (superávit 300 kcal)</option>
                  <option value="500">Bulking (superávit 500 kcal)</option>
                </select>
              </div>
              <div class="form-row">
                <label>Meta de proteína (g/kg)</label>
                <input type="number" step="0.1" id="cnProtKg" value="1.8" min="1" max="3">
