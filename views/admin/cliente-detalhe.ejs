<%- include('../partials/head') %>
<div class="app">
  <%- include('../partials/sidebar-admin') %>
  <main class="main">
    <div class="topbar">
      <div>
        <a href="/admin/clientes" class="text-muted fs-sm">← Clientes</a>
        <h1><%= cliente.name %></h1>
        <p class="text-muted mb-0">
          <span class="badge <%= cliente.status === 'ativo' ? 'badge-success' : 'badge-info' %>"><%= cliente.status %></span>
          <span class="badge badge-outline">Semana <%= cliente.current_week %></span>
          <span class="badge badge-outline"><%= cliente.plan || '—' %></span>
          <span class="badge" style="background:var(--accent);color:#000">🏆 <%= cliente.gym_cats_points %> pts</span>
        </p>
      </div>
    </div>
    <%- include('../partials/flash') %>

    <div class="flex-gap gap-1 mb-2" style="flex-wrap:wrap">
      <a href="/admin/clientes/<%= cliente.id %>/progressao" class="btn btn-sm btn-outline">📊 Progressão de carga</a>
    </div>

    <div class="tabs">
      <a href="#" class="tab-btn active" data-target="#tab-info">Informações</a>
      <a href="#" class="tab-btn" data-target="#tab-treinos">Fichas (Treinos)</a>
      <a href="#" class="tab-btn" data-target="#tab-dieta">Fichas (Dieta)</a>
      <a href="#" class="tab-btn" data-target="#tab-feedback">Atualizações</a>
      <a href="#" class="tab-btn" data-target="#tab-nutricao">Nutrição</a>
      <a href="#" class="tab-btn" data-target="#tab-historico">Histórico semanal</a>
      <a href="#" class="tab-btn" data-target="#tab-questionario">Questionário</a>
    </div>

    <style> .tab-pane { display: none; } .tab-pane.active { display: block; } </style>

    <!-- INFO -->
    <div id="tab-info" class="tab-pane active">
      <div class="grid grid-2">
        <div class="card">
          <h3>Dados do cliente</h3>
          <form action="/admin/clientes/<%= cliente.id %>/update" method="POST">
            <div class="form-row">
              <label>Nome</label>
              <input type="text" name="name" value="<%= cliente.name %>" required>
            </div>
            <div class="form-grid">
              <div class="form-row">
                <label>Whatsapp</label>
                <input type="tel" name="phone" value="<%= cliente.phone || '' %>">
              </div>
              <div class="form-row">
                <label>Instagram</label>
                <input type="text" name="instagram" value="<%= cliente.instagram || '' %>">
              </div>
            </div>
            <div class="form-grid">
              <div class="form-row">
                <label>Plano</label>
                <input type="text" name="plan" value="<%= cliente.plan || '' %>">
              </div>
              <div class="form-row">
                <label>Duração</label>
                <input type="text" name="plan_duration" value="<%= cliente.plan_duration || '' %>">
              </div>
            </div>
            <div class="form-grid">
              <div class="form-row">
                <label>Valor (R$)</label>
                <input type="number" step="0.01" name="value" value="<%= cliente.value || '' %>">
              </div>
              <div class="form-row">
                <label>Semana atual</label>
                <input type="number" name="current_week" value="<%= cliente.current_week %>" min="1">
              </div>
            </div>
            <div class="form-row">
              <label>Status</label>
              <select name="status">
                <option value="implementacao" <%= cliente.status === 'implementacao' ? 'selected' : '' %>>Implementação</option>
                <option value="ativo" <%= cliente.status === 'ativo' ? 'selected' : '' %>>Ativo</option>
                <option value="pausado" <%= cliente.status === 'pausado' ? 'selected' : '' %>>Pausado</option>
                <option value="encerrado" <%= cliente.status === 'encerrado' ? 'selected' : '' %>>Encerrado</option>
              </select>
            </div>
            <button class="btn" type="submit">Salvar</button>
          </form>
        </div>

        <div>
          <div class="card">
            <h3>Permissão de print</h3>
            <p class="fs-sm text-muted mb-2">
              Por padrão, ao tirar print das telas de treino, aparece uma marca d'água VS TEAM sobre o conteúdo. Libere apenas para clientes de confiança.
            </p>
            <% if (cliente.allow_screenshot) { %>
              <div class="alert success" style="margin-bottom:10px">Print liberado para este cliente.</div>
            <% } else { %>
              <div class="alert" style="margin-bottom:10px">Watermark ativa — clientes vê marca VS TEAM sobre os treinos ao printar.</div>
            <% } %>
            <form action="/admin/clientes/<%= cliente.id %>/screenshot-toggle" method="POST" style="margin:0">
              <button class="btn btn-block <%= cliente.allow_screenshot ? 'btn-ghost' : '' %>" type="submit">
                <%= cliente.allow_screenshot ? 'Bloquear print (ativar watermark)' : 'Liberar print sem watermark' %>
              </button>
            </form>
          </div>

          <div class="card" style="border-left:3px solid var(--accent)">
            <h3>Vigência do plano</h3>
            <% var _exp = (function(d){
              if (!d) return null;
              const today = new Date(); today.setHours(0,0,0,0);
              const end = new Date(d + 'T00:00:00');
              const days = Math.round((end.getTime() - today.getTime())/86400000);
              if (days < 0) return { txt: 'Vencido há ' + Math.abs(days) + ' dia(s)', cls: 'danger' };
              if (days === 0) return { txt: 'Vence hoje', cls: 'warning' };
              if (days <= 7) return { txt: 'Vence em ' + days + ' dia(s)', cls: 'warning' };
              return { txt: days + ' dias restantes', cls: 'success' };
            })(cliente.end_date); %>

            <% if (cliente.end_date) { %>
              <p class="fs-sm">
                <strong>Vence em:</strong> <%= cliente.end_date.split('-').reverse().join('/') %>
                · <span class="badge badge-<%= _exp.cls %>"><%= _exp.txt %></span>
              </p>
            <% } else { %>
              <p class="fs-sm text-muted">Sem data de vencimento definida.</p>
            <% } %>

            <form action="/admin/clientes/<%= cliente.id %>/vigencia" method="POST" class="mt-2">
              <div class="flex-gap gap-1" style="align-items:flex-end">
                <div class="form-row" style="flex:1; margin:0">
                  <label>Atualizar vigência</label>
                  <input type="date" name="end_date" value="<%= cliente.end_date || '' %>">
                </div>
                <button class="btn btn-sm" type="submit">Salvar</button>
              </div>
            </form>

            <div class="mt-2">
              <p class="fs-sm text-muted mb-1">Renovar rapidamente:</p>
              <div class="flex-gap gap-1" style="flex-wrap:wrap">
                <% [1, 3, 6, 12].forEach(function(m){ %>
                  <form action="/admin/clientes/<%= cliente.id %>/renovar" method="POST" style="margin:0">
                    <input type="hidden" name="meses" value="<%= m %>">
                    <button class="btn btn-sm btn-outline" type="submit">+ <%= m %> <%= m === 1 ? 'mês' : 'meses' %></button>
                  </form>
                <% }); %>
              </div>
            </div>
          </div>

          <div class="card">
            <h3>Login do cliente</h3>
            <p class="fs-sm text-muted">Acesso pelo email: <strong><%= cliente.email %></strong></p>
            <p class="fs-sm text-muted" style="margin-bottom:14px">As senhas são armazenadas criptografadas — não dá pra "ver" a senha atual. Mas você pode definir uma nova quando o aluno esquecer:</p>
            <form action="/admin/clientes/<%= cliente.id %>/reset-senha" method="POST" data-confirm="Redefinir senha deste aluno? A nova senha aparecerá uma vez na tela.">
              <div class="form-row">
                <label>Nova senha (mínimo 6 caracteres)</label>
                <div class="flex-gap gap-1">
                  <input type="text" name="password" id="newPwInput" minlength="6" required placeholder="Digite ou clique em Gerar" style="flex:1">
                  <button type="button" class="btn btn-sm btn-outline" id="genPwBtn">🎲 Gerar</button>
                </div>
                <small class="text-muted fs-sm">Sugira ao aluno trocar depois no perfil dele.</small>
              </div>
              <button type="submit" class="btn btn-block" style="background:var(--warning);color:#000">Resetar senha do aluno</button>
            </form>
            <script>
              document.getElementById('genPwBtn')?.addEventListener('click', () => {
                const chars = 'abcdefghjkmnpqrstuvwxyzABCDEFGHJKMNPQRSTUVWXYZ23456789';
                let pw = '';
                for (let i = 0; i < 10; i++) pw += chars[Math.floor(Math.random() * chars.length)];
                document.getElementById('newPwInput').value = pw;
              });
            </script>
          </div>

          <% if (cliente.status === 'implementacao') { %>
          <div class="card" style="border-color:var(--success)">
            <h3 style="color:var(--success)">🚀 Mover para Gestão Contínua</h3>
            <p class="fs-sm text-muted">Assim que questionário + fotos + primeiro treino estiverem prontos.</p>
            <form action="/admin/clientes/<%= cliente.id %>/implementation-step" method="POST">
              <input type="hidden" name="finalize" value="1">
              <button class="btn btn-success btn-block" type="submit">Finalizar Implementação</button>
            </form>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- QUESTIONÁRIO -->
    <div id="tab-questionario" class="tab-pane">
      <div class="card">
        <h3>Questionário Inicial</h3>
        <% if (questionnaire) { %>
          <p class="fs-sm text-muted">Enviado em <%= questionnaire.submitted_at.slice(0,10) %></p>
          <div class="grid grid-2 mt-2">
            <div><strong>Objetivo:</strong> <%= questionnaire.goal || '—' %></div>
            <div><strong>Experiência:</strong> <%= questionnaire.experience || '—' %></div>
            <div><strong>Peso:</strong> <%= questionnaire.weight || '—' %> kg</div>
            <div><strong>Altura:</strong> <%= questionnaire.height || '—' %> cm</div>
            <div><strong>Idade:</strong> <%= questionnaire.age || '—' %></div>
            <div><strong>Dias/semana:</strong> <%= questionnaire.available_days || '—' %></div>
            <div><strong>Local de treino:</strong> <%= questionnaire.training_location || '—' %></div>
            <div><strong>Restrições alim.:</strong> <%= questionnaire.food_restrictions || '—' %></div>
            <div style="grid-column:1/-1"><strong>Preferências alimentares:</strong> <%= questionnaire.food_preferences || '—' %></div>
            <div style="grid-column:1/-1"><strong>Histórico médico:</strong> <%= questionnaire.medical_history || '—' %></div>
            <div style="grid-column:1/-1"><strong>Notas:</strong> <%= questionnaire.notes || '—' %></div>
          </div>
        <% } else { %>
          <p class="text-muted">Questionário ainda não preenchido.</p>
        <% } %>
      </div>
      <div class="card">
        <h3>Preencher / Atualizar questionário</h3>
        <form action="/admin/clientes/<%= cliente.id %>/questionario" method="POST">
          <div class="form-row"><label>Objetivo</label><input type="text" name="goal" value="<%= questionnaire ? questionnaire.goal || '' : '' %>"></div>
          <div class="form-grid">
            <div class="form-row"><label>Experiência</label><input type="text" name="experience" value="<%= questionnaire ? questionnaire.experience || '' : '' %>"></div>
            <div class="form-row"><label>Idade</label><input type="number" name="age" value="<%= questionnaire ? questionnaire.age || '' : '' %>"></div>
          </div>
          <div class="form-grid">
            <div class="form-row"><label>Peso (kg)</label><input type="number" step="0.1" name="weight" value="<%= questionnaire ? questionnaire.weight || '' : '' %>"></div>
            <div class="form-row"><label>Altura (cm)</label><input type="number" step="0.1" name="height" value="<%= questionnaire ? questionnaire.height || '' : '' %>"></div>
          </div>
          <div class="form-grid">
            <div class="form-row"><label>Dias/semana</label><input type="number" name="available_days" value="<%= questionnaire ? questionnaire.available_days || '' : '' %>"></div>
            <div class="form-row"><label>Local de treino</label><input type="text" name="training_location" value="<%= questionnaire ? questionnaire.training_location || '' : '' %>"></div>
          </div>
          <div class="form-row"><label>Preferências alimentares</label><textarea name="food_preferences"><%= questionnaire ? questionnaire.food_preferences || '' : '' %></textarea></div>
          <div class="form-row"><label>Restrições</label><textarea name="food_restrictions"><%= questionnaire ? questionnaire.food_restrictions || '' : '' %></textarea></div>
          <div class="form-row"><label>Histórico médico</label><textarea name="medical_history"><%= questionnaire ? questionnaire.medical_history || '' : '' %></textarea></div>
          <div class="form-row"><label>Notas</label><textarea name="notes"><%= questionnaire ? questionnaire.notes || '' : '' %></textarea></div>
          <button class="btn" type="submit">Salvar</button>
        </form>
      </div>
    </div>

    <!-- TREINOS -->
    <div id="tab-treinos" class="tab-pane">
      <% if (typeof treinoTpls !== 'undefined' && treinoTpls.length > 0) { %>
      <div class="card" style="border-left:3px solid var(--accent)">
        <h3>Aplicar template de treino</h3>
        <p class="fs-sm text-muted">Aplique um treino pré-montado neste cliente em 1 clique. O template é copiado e fica editável aqui.</p>
        <form action="/admin/clientes/<%= cliente.id %>/aplicar-template-treino" method="POST" class="form-grid" style="align-items:end">
          <div class="form-row" style="grid-column:1/-1">
            <label>Escolher template</label>
            <select name="template_id" required>
              <option value="">— selecione —</option>
              <% treinoTpls.forEach(function(tpl){ %>
                <option value="<%= tpl.id %>"><%= tpl.name %><% if (tpl.focus) { %> · <%= tpl.focus %><% } %><% if (tpl.ex_count) { %> · <%= tpl.ex_count %> exs<% } %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-row">
            <label>Semana</label>
            <input type="number" name="week_number" value="<%= cliente.current_week %>" min="1" required>
          </div>
          <div class="form-row">
            <label>Letra</label>
            <input type="text" name="day_label" placeholder="A, B, C... (opcional)">
          </div>
          <button class="btn" type="submit">Aplicar</button>
        </form>
      </div>
      <% } %>

      <div class="card">
        <h3>+ Novo Treino</h3>
        <form action="/admin/clientes/<%= cliente.id %>/treinos" method="POST" class="form-grid" style="align-items:end">
          <div class="form-row">
            <label>Semana</label>
            <input type="number" name="week_number" value="<%= cliente.current_week %>" min="1" required>
          </div>
          <div class="form-row">
            <label>Dia (letra)</label>
            <input type="text" name="day_label" placeholder="A, B, C..." required>
          </div>
          <div class="form-row">
            <label>Título</label>
            <input type="text" name="title" placeholder="Peito + Tríceps" required>
          </div>
          <div class="form-row">
            <label>Foco</label>
            <select name="focus"><option>Hipertrofia</option><option>Força</option><option>Resistência</option><option>Definição</option></select>
          </div>
          <div class="form-row" style="grid-column:1/-1">
            <label>Notas do treino</label>
            <textarea name="notes" rows="2"></textarea>
          </div>
          <button class="btn" type="submit">Adicionar Treino</button>
        </form>
      </div>

      <div class="card" style="background:transparent;border:0;padding:0;margin-bottom:14px">
        <a href="/admin/clientes/<%= cliente.id %>/pdf-treino?week=<%= cliente.current_week %>" target="_blank" class="btn btn-outline">
          📄 Exportar PDF do treino (semana <%= cliente.current_week %>)
        </a>
      </div>

      <% workouts.forEach(function(w){ var exs = w.exercises || []; %>
        <div class="card">
          <div class="flex-between mb-2">
            <div>
              <h3 style="margin-bottom:3px">Semana <%= w.week_number %> — Treino <%= w.day_label %>: <%= w.title %></h3>
              <div class="fs-sm text-muted"><%= w.focus %> · <%= w.notes || '' %></div>
            </div>
            <div class="flex-gap gap-1">
              <button type="button" class="btn btn-sm btn-outline btn-dup-treino" data-workout-id="<%= w.id %>" data-workout-name="<%= w.day_label %>: <%= w.title %>">Duplicar</button>
              <form action="/admin/treinos/<%= w.id %>/delete" method="POST" data-confirm="Remover este treino?" style="margin:0">
                <input type="hidden" name="client_id" value="<%= cliente.id %>">
                <button class="btn btn-sm btn-ghost" type="submit">🗑</button>
              </form>
            </div>
          </div>

          <% if (exs.length > 0) { %>
            <table class="table">
              <thead><tr><th>Exercício</th><th>Séries × Reps</th><th>Descanso</th><th>Carga</th><th></th></tr></thead>
              <tbody>
                <% exs.forEach(function(e){ %>
                  <tr>
                    <td>
                      <strong><%= e.name %></strong>
                      <% if (e.notes) { %><div class="fs-sm text-muted"><%= e.notes %></div><% } %>
                    </td>
                    <td><%= e.sets %> × <%= e.reps %></td>
                    <td><%= e.rest %></td>
                    <td><%= e.load_kg ? e.load_kg + ' kg' : '—' %></td>
                    <td>
                      <form action="/admin/exercicios/<%= e.id %>/delete" method="POST" style="margin:0">
                        <input type="hidden" name="client_id" value="<%= cliente.id %>">
                        <button class="btn btn-sm btn-ghost" type="submit" title="Remover">×</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <p class="text-muted fs-sm">Sem exercícios ainda.</p>
          <% } %>

          <div class="flex-gap gap-1 mt-2" style="flex-wrap:wrap">
            <button type="button" class="btn btn-sm btn-outline btn-import-ex" data-workout-id="<%= w.id %>">📥 Importar exercícios</button>
            <details style="display:inline-block">
              <summary class="btn btn-sm btn-outline" style="list-style:none">+ Adicionar exercício</summary>
              <form action="/admin/treinos/<%= w.id %>/exercicios" method="POST" class="mt-2">
                <input type="hidden" name="client_id" value="<%= cliente.id %>">
                <div class="form-grid">
                  <div class="form-row"><label>Nome *</label><input type="text" name="name" required></div>
                  <div class="form-row"><label>Vídeo (URL embed)</label><input type="text" name="video_url" placeholder="https://youtube.com/embed/..."></div>
                </div>
                <div class="form-grid">
                  <div class="form-row"><label>Séries</label><input type="text" name="sets" placeholder="4"></div>
                  <div class="form-row"><label>Repetições</label><input type="text" name="reps" placeholder="8-10"></div>
                  <div class="form-row"><label>Descanso</label><input type="text" name="rest" placeholder="90s"></div>
                  <div class="form-row"><label>Carga (kg)</label><input type="text" name="load_kg"></div>
                </div>
                <div class="form-row"><label>Observação</label><textarea name="notes" rows="2"></textarea></div>
                <button class="btn btn-sm" type="submit">Salvar exercício</button>
              </form>
            </details>
          </div>
        </div>
      <% }); %>
      <% if (workouts.length === 0) { %>
        <div class="card text-center"><p class="text-muted">Nenhum treino cadastrado ainda.</p></div>
      <% } %>
    </div>

    <!-- DIETA -->
    <div id="tab-dieta" class="tab-pane">
      <% if (typeof dietaTpls !== 'undefined' && dietaTpls.length > 0) { %>
      <div class="card" style="border-left:3px solid var(--accent)">
        <h3>Aplicar template de dieta</h3>
        <p class="fs-sm text-muted">Aplique um plano alimentar pré-montado em 1 clique.</p>
        <form action="/admin/clientes/<%= cliente.id %>/aplicar-template-dieta" method="POST" class="form-grid" style="align-items:end">
          <div class="form-row" style="grid-column:1/-1">
            <label>Escolher template</label>
            <select name="template_id" required>
              <option value="">— selecione —</option>
              <% dietaTpls.forEach(function(tpl){ %>
                <option value="<%= tpl.id %>"><%= tpl.name %><% if (tpl.calories) { %> · <%= tpl.calories %> kcal<% } %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-row">
            <label>Semana</label>
            <input type="number" name="week_number" value="<%= cliente.current_week %>" min="1" required>
          </div>
          <button class="btn" type="submit">Aplicar</button>
        </form>
      </div>
      <% } %>

      <div class="card">
        <h3>+ Nova Dieta</h3>
        <form action="/admin/clientes/<%= cliente.id %>/dietas" method="POST">
          <div class="form-grid">
            <div class="form-row"><label>Semana</label><input type="number" name="week_number" value="<%= cliente.current_week %>" min="1" required></div>
            <div class="form-row"><label>Calorias</label><input type="number" name="calories" placeholder="3000"></div>
          </div>
          <div class="form-grid">
            <div class="form-row"><label>Proteína (g)</label><input type="number" name="protein"></div>
            <div class="form-row"><label>Carbo (g)</label><input type="number" name="carbs"></div>
            <div class="form-row"><label>Gordura (g)</label><input type="number" name="fats"></div>
          </div>
          <div class="form-row">
            <label>Plano alimentar</label>
            <textarea name="meal_plan" rows="8" placeholder="Café: ...&#10;Almoço: ...&#10;Lanche: ...&#10;Jantar: ..."></textarea>
          </div>
          <div class="form-row"><label>Notas (suplementação, hidratação...)</label><textarea name="notes" rows="2"></textarea></div>
          <button class="btn" type="submit">Salvar Dieta</button>
        </form>
      </div>

      <div class="card" style="background:transparent;border:0;padding:0;margin-bottom:14px">
        <a href="/admin/clientes/<%= cliente.id %>/pdf-dieta?week=<%= cliente.current_week %>" target="_blank" class="btn btn-outline">
          📄 Exportar PDF da dieta (semana <%= cliente.current_week %>)
        </a>
      </div>

      <% diets.forEach(function(d){ %>
        <div class="card">
          <div class="flex-between mb-1">
            <div>
              <h3 style="margin-bottom:3px">Semana <%= d.week_number %> — <%= d.calories || 0 %> kcal</h3>
              <div class="fs-sm text-muted">P: <%= d.protein || 0 %>g · C: <%= d.carbs || 0 %>g · G: <%= d.fats || 0 %>g</div>
            </div>
            <button type="button" class="btn btn-sm btn-outline btn-dup-dieta" data-diet-id="<%= d.id %>" data-diet-name="Semana <%= d.week_number %> — <%= d.calories || 0 %>kcal">Duplicar</button>
          </div>
          <pre style="background:var(--bg-soft);padding:14px;border-radius:6px;white-space:pre-wrap;margin-top:10px;font-family:inherit"><%= d.meal_plan %></pre>
          <% if (d.notes) { %><p class="fs-sm text-muted"><strong>Notas:</strong> <%= d.notes %></p><% } %>
        </div>
      <% }); %>
    </div>

    <!-- FOTOS -->
    <div id="tab-fotos" class="tab-pane">
      <div class="card">
        <h3>Upload de foto (pelo admin)</h3>
        <form action="/admin/clientes/<%= cliente.id %>/fotos" method="POST" enctype="multipart/form-data">
          <div class="form-grid">
            <div class="form-row">
              <label>Categoria</label>
              <select name="category">
                <option value="antes">Antes</option>
