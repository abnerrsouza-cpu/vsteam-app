<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    @page { size: A4; margin: 16mm 14mm; }
    * { box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; background: #fff; color: #111; margin: 0; padding: 24px; font-size: 13px; line-height: 1.55; }
    .pdf-bar { position: sticky; top: 0; background: #fff; padding: 12px 16px; margin: -24px -24px 18px; border-bottom: 1px solid #ddd; display: flex; gap: 10px; justify-content: flex-end; z-index: 10; }
    .pdf-bar button, .pdf-bar a { padding: 8px 16px; background: #e50914; color: #fff; border: 0; border-radius: 6px; font-weight: 700; font-size: 13px; cursor: pointer; text-decoration: none; }
    .pdf-bar a.ghost { background: #eee; color: #333; }
    @media print { .pdf-bar { display: none; } body { padding: 0; } }

    .doc { max-width: 760px; margin: 0 auto; }
    .doc-header { border-top: 4px solid #e50914; padding: 18px 0 14px; margin-bottom: 18px; display: flex; justify-content: space-between; align-items: flex-end; }
    .doc-header .brand { font-weight: 900; font-size: 24px; letter-spacing: 3px; color: #111; }
    .doc-header .brand .red { color: #e50914; }
    .doc-header .brand-sub { font-size: 9px; letter-spacing: 4px; color: #888; margin-top: 2px; }
    .doc-header img.logo { max-height: 60px; }
    .doc-meta { font-size: 11px; color: #555; text-align: right; }
    .doc-meta strong { color: #111; font-size: 13px; }

    .client-card { background: #f7f7f7; border-radius: 8px; padding: 14px 16px; margin-bottom: 18px; }
    .client-card .name { font-size: 18px; font-weight: 800; margin-bottom: 2px; }
    .client-card .meta { font-size: 11px; color: #666; }

    .macros {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 10px; margin-bottom: 22px;
    }
    .macro { background: #f7f7f7; border-radius: 8px; padding: 12px; text-align: center; border-top: 3px solid #e50914; }
    .macro .v { font-size: 22px; font-weight: 900; line-height: 1; }
    .macro .l { font-size: 9px; color: #888; letter-spacing: 1.5px; text-transform: uppercase; margin-top: 4px; }

    .meal-plan {
      background: #fafafa; border: 1px solid #eee; border-radius: 8px;
      padding: 18px;
      white-space: pre-wrap;
      font-family: inherit;
      font-size: 13px; line-height: 1.7;
    }

    .notes-block {
      margin-top: 18px; padding: 14px;
      background: #fff8f0; border-left: 4px solid #ffc107;
      border-radius: 6px;
      font-size: 12px;
    }
    .notes-block strong { color: #b87a00; }

    .footer { margin-top: 30px; padding-top: 14px; border-top: 1px solid #ddd; font-size: 10px; color: #888; display: flex; justify-content: space-between; }
    .signature { margin-top: 50px; padding-top: 6px; border-top: 1px solid #111; width: 300px; font-size: 10px; color: #555; text-align: center; }

    .empty { padding: 40px; text-align: center; color: #999; border: 2px dashed #ddd; border-radius: 8px; }
  </style>
</head>
<body>
  <div class="pdf-bar">
    <a href="/admin/clientes/<%= cliente.id %>" class="ghost">← Voltar</a>
    <button onclick="window.print()">Imprimir / Salvar como PDF</button>
  </div>

  <div class="doc">
    <div class="doc-header">
      <div>
        <% if (hasLogo) { %>
          <img class="logo" src="/logos/logo.png" alt="VS TEAM">
        <% } else { %>
          <div class="brand">VS<span class="red">TEAM</span></div>
          <div class="brand-sub">CONSULTORIA ONLINE</div>
        <% } %>
      </div>
      <div class="doc-meta">
        <strong>FICHA DE DIETA</strong>
        <div>Semana <%= week %></div>
        <div>Gerado em <%= geradoEm %></div>
      </div>
    </div>

    <div class="client-card">
      <div class="name"><%= cliente.name %></div>
      <div class="meta">
        <%= cliente.plan || 'Consultoria VS TEAM' %>
        <% if (cliente.email) { %> · <%= cliente.email %><% } %>
      </div>
    </div>

    <% if (!diet) { %>
      <div class="empty">Nenhuma dieta cadastrada para a semana <%= week %>.</div>
    <% } else { %>

      <div class="macros">
        <div class="macro">
          <div class="v"><%= diet.calories || '—' %></div>
          <div class="l">KCAL</div>
        </div>
        <div class="macro">
          <div class="v"><%= diet.protein != null ? diet.protein + 'g' : '—' %></div>
          <div class="l">PROTEÍNA</div>
        </div>
        <div class="macro">
          <div class="v"><%= diet.carbs != null ? diet.carbs + 'g' : '—' %></div>
          <div class="l">CARBO</div>
        </div>
        <div class="macro">
          <div class="v"><%= diet.fats != null ? diet.fats + 'g' : '—' %></div>
          <div class="l">GORDURA</div>
        </div>
      </div>

      <h2 style="font-size:14px; letter-spacing:1px; text-transform:uppercase; color:#555; margin-bottom:8px">Plano alimentar</h2>
      <div class="meal-plan"><%= diet.meal_plan || 'Sem plano cadastrado.' %></div>

      <% if (diet.notes) { %>
        <div class="notes-block">
          <strong>Observações importantes:</strong><br>
          <%= diet.notes %>
        </div>
      <% } %>
    <% } %>

    <div class="signature">Victor Augusto — VS TEAM</div>

    <div class="footer">
      <div>VS TEAM Consultoria Online · Documento gerado automaticamente</div>
      <div><%= geradoEm %></div>
    </div>
  </div>
</body>
</html>
