<%- include('../partials/head') %>
<div class="app">
  <%- include('../partials/sidebar-client') %>
  <main class="main">
    <div class="topbar">
      <div>
        <h1>Ficha de Avaliação</h1>
        <p class="text-muted mb-0">Envie até sábado. Vale <strong class="text-primary">+40 pts Gym Cats</strong>. Anexar fotos dá <strong class="text-primary">+30 pts cada</strong>.</p>
      </div>
    </div>
    <%- include('../partials/flash') %>

    <% if ((locals.template || []).length === 0) { %>
      <div class="card text-center">
        <p class="text-muted">O Victor ainda não configurou os campos da ficha. Volte em instantes.</p>
      </div>
    <% } else { %>
    <div class="grid grid-2">
      <div class="card">
        <h3>Nova Ficha</h3>
        <form action="/cliente/avaliacao" method="POST" enctype="multipart/form-data">
          <% locals.template.forEach(function(q){ %>
            <div class="form-row">
              <label>
                <%= q.label %>
                <% if (q.unit) { %> <span class="text-muted">(<%= q.unit %>)</span><% } %>
                <% if (q.required) { %> <span class="text-primary">*</span><% } %>
              </label>
              <% if (q.field_type === 'textarea') { %>
                <textarea name="<%= q.q_key %>" rows="3" <%= q.required ? 'required' : '' %>></textarea>
              <% } else if (q.field_type === 'text') { %>
                <input type="text" name="<%= q.q_key %>" <%= q.required ? 'required' : '' %>>
              <% } else { %>
                <input type="number" step="0.1" name="<%= q.q_key %>" <%= q.required ? 'required' : '' %>>
              <% } %>
            </div>
          <% }); %>

          <div class="upload-zone">
            <label class="upload-label">Fotos de acompanhamento (opcional — até 4)</label>
            <p class="fs-sm text-muted mb-2">Anexe agora pra ficha + foto irem juntos (+30 pts cada).</p>
            <label class="upload-drop" id="uploadDrop">
              <input type="file" name="photos" id="uploadInput" accept="image/*" multiple style="display:none">
              <div class="upload-cta">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="28" height="28">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="17 8 12 3 7 8"/>
                  <line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                <div>
                  <strong>Clique para selecionar imagens</strong>
                  <div class="fs-sm text-muted">ou arraste e solte (jpg, png — máx. 10MB cada)</div>
                </div>
              </div>
            </label>
            <div class="upload-preview" id="uploadPreview"></div>
          </div>

          <button class="btn btn-block" type="submit">Enviar Ficha (+40 pts)</button>
        </form>
      </div>

      <div class="card">
        <h3>Histórico (<%= evals.length %>)</h3>
        <% if (evals.length === 0) { %>
          <p class="text-muted">Sem fichas enviadas ainda. Bora começar!</p>
        <% } else { %>
          <% evals.forEach(function(e){
            var ans = {};
            if (e.answers_json) { try { ans = JSON.parse(e.answers_json) || {}; } catch(_) {} }
          %>
            <div style="padding:12px;background:var(--bg-soft);border-radius:8px;margin-bottom:8px">
              <div class="flex-between">
                <strong><%= e.submitted_at.slice(0,10).split('-').reverse().join('/') %></strong>
              </div>
              <div class="fs-sm mt-1">
                <% locals.template.forEach(function(q){
                  var v = ans[q.q_key];
                  if (!v) {
                    // fallback pra colunas legadas
                    if (q.q_key === 'weight') v = e.weight;
                    else if (q.q_key === 'chest') v = e.chest;
                    else if (q.q_key === 'waist') v = e.waist;
                    else if (q.q_key === 'hip') v = e.hip;
                    else if (q.q_key === 'arm') v = e.arm;
                    else if (q.q_key === 'leg') v = e.leg;
                    else if (q.q_key === 'notes') v = e.notes;
                  }
                  if (v) {
                %>
                  <span style="display:inline-block; margin-right:10px"><strong><%= q.label %>:</strong> <%= v %><% if (q.unit) { %><%= q.unit %><% } %></span>
                <% } }); %>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>
    <% } %>
  </main>
</div>
<script>
(function(){
  const input = document.getElementById('uploadInput');
  const drop = document.getElementById('uploadDrop');
  const preview = document.getElementById('uploadPreview');
  if (!input || !drop) return;
  function render(files) {
    preview.innerHTML = '';
    Array.from(files).slice(0, 4).forEach(f => {
      if (!f.type.startsWith('image/')) return;
      const url = URL.createObjectURL(f);
      const div = document.createElement('div');
      div.className = 'upload-thumb';
      div.innerHTML = '<img src="'+url+'"><span>'+f.name+'</span>';
      preview.appendChild(div);
    });
  }
  input.addEventListener('change', () => render(input.files));
  ['dragenter','dragover'].forEach(ev => drop.addEventListener(ev, e => { e.preventDefault(); drop.classList.add('drag'); }));
  ['dragleave','drop'].forEach(ev => drop.addEventListener(ev, e => { e.preventDefault(); drop.classList.remove('drag'); }));
  drop.addEventListener('drop', e => { if (e.dataTransfer.files.length) { input.files = e.dataTransfer.files; render(input.files); } });
})();
</script>
<%- include('../partials/foot') %>
