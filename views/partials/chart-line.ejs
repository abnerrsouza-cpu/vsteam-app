<%
// Chart de linha SVG inline. Recebe: points = [{date, weight, volume, sets}], height
const _h = typeof height !== 'undefined' ? height : 140;
const _pad = { l: 32, r: 12, t: 12, b: 22 };
const _w = 460;
const _innerW = _w - _pad.l - _pad.r;
const _innerH = _h - _pad.t - _pad.b;
const weights = points.map(p => p.weight);
const minW = Math.min.apply(null, weights);
const maxW = Math.max.apply(null, weights);
const rangeW = (maxW - minW) || 1;
const padW = rangeW * 0.15;
const yMin = Math.max(0, minW - padW);
const yMax = maxW + padW;
const yRange = (yMax - yMin) || 1;

function xOf(i) { return _pad.l + (points.length === 1 ? _innerW / 2 : (i / (points.length - 1)) * _innerW); }
function yOf(v) { return _pad.t + _innerH - ((v - yMin) / yRange) * _innerH; }

const path = points.map((p, i) => (i === 0 ? 'M' : 'L') + xOf(i).toFixed(1) + ',' + yOf(p.weight).toFixed(1)).join(' ');
const areaPath = path + ' L' + xOf(points.length - 1).toFixed(1) + ',' + (_pad.t + _innerH) + ' L' + xOf(0).toFixed(1) + ',' + (_pad.t + _innerH) + ' Z';
%>
<svg viewBox="0 0 <%= _w %> <%= _h %>" style="width:100%;height:auto;display:block" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad-<%= points[0].date.replace(/-/g,'') %>-<%= Math.random().toString(36).slice(2,6) %>" x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color="#e50914" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="#e50914" stop-opacity="0"/>
    </linearGradient>
  </defs>

  <!-- Eixos -->
  <line x1="<%= _pad.l %>" y1="<%= _pad.t %>" x2="<%= _pad.l %>" y2="<%= _pad.t + _innerH %>" stroke="#333" stroke-width="1"/>
  <line x1="<%= _pad.l %>" y1="<%= _pad.t + _innerH %>" x2="<%= _w - _pad.r %>" y2="<%= _pad.t + _innerH %>" stroke="#333" stroke-width="1"/>

  <!-- Grid horizontal -->
  <% [0.25, 0.5, 0.75].forEach(function(p){ const y = _pad.t + _innerH * p; %>
    <line x1="<%= _pad.l %>" y1="<%= y %>" x2="<%= _w - _pad.r %>" y2="<%= y %>" stroke="#222" stroke-dasharray="2,3"/>
  <% }); %>

  <!-- Labels do eixo Y -->
  <text x="<%= _pad.l - 4 %>" y="<%= _pad.t + 4 %>" text-anchor="end" fill="#888" font-size="9"><%= yMax.toFixed(0) %>kg</text>
  <text x="<%= _pad.l - 4 %>" y="<%= _pad.t + _innerH %>" text-anchor="end" fill="#888" font-size="9"><%= yMin.toFixed(0) %>kg</text>

  <!-- Área e linha -->
  <path d="<%= areaPath %>" fill="rgba(229,9,20,0.15)"/>
  <path d="<%= path %>" fill="none" stroke="#e50914" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>

  <!-- Pontos -->
  <% points.forEach(function(p, i){ %>
    <g>
      <circle cx="<%= xOf(i) %>" cy="<%= yOf(p.weight) %>" r="4" fill="#e50914" stroke="#fff" stroke-width="1.5">
        <title><%= p.date.split('-').reverse().join('/') %> — <%= p.weight %>kg</title>
      </circle>
    </g>
  <% }); %>

  <!-- Labels do eixo X -->
  <% if (points.length > 0) {
    const first = points[0]; const last = points[points.length - 1];
  %>
    <text x="<%= xOf(0) %>" y="<%= _h - 6 %>" text-anchor="middle" fill="#888" font-size="9"><%= first.date.split('-').slice(1).reverse().join('/') %></text>
    <% if (points.length > 1) { %>
      <text x="<%= xOf(points.length - 1) %>" y="<%= _h - 6 %>" text-anchor="middle" fill="#888" font-size="9"><%= last.date.split('-').slice(1).reverse().join('/') %></text>
    <% } %>
  <% } %>
</svg>
